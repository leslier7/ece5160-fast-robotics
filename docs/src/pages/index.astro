---
import Layout from '../layouts/Layout.astro';
import { getCollection } from 'astro:content';
import { Image } from 'astro:assets';
import { ArrowRight, Mail, Github, Linkedin } from 'lucide-react';
import { SITE } from '../config';
import headshot from '../assets/headshot.jpg';

// Use activities as your lab reports
const labs = (await getCollection('labs'))
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf())
  .slice(0, 3);
---

<Layout title="Home" fullHeight={true}>
  <!-- Hero Section with Full Photo -->
  <section class="flex-grow flex items-center py-16 bg-gradient-to-br from-gray-50 to-gray-100">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="flex flex-col md:flex-row items-center gap-12">
        <!-- Full Photo -->
        <div class="flex-shrink-0 w-full md:w-1/3">
          <Image 
            src={headshot}
            alt={SITE.hero.title}
            class="w-full h-auto rounded-2xl shadow-xl"
            quality={85}
            format="webp"
            widths={[300, 400, 500]}
            sizes="(max-width: 768px) 100vw, 33vw"
          />
        </div>
        
        <!-- Text Content -->
        <div class="w-full md:w-2/3 text-center md:text-left">
          <h1 class="text-4xl font-extrabold text-gray-900 sm:text-5xl lg:text-6xl mb-6">
            {SITE.hero.title}
          </h1>
          <p class="text-xl text-gray-600 mb-4 leading-relaxed">
            {SITE.hero.subtitle}
          </p>
          <p class="text-lg text-gray-500 mb-6 leading-relaxed">
            {SITE.hero.about}
          </p>
          
          <!-- Contact Links -->
          <div class="flex items-center gap-6 mb-8 justify-center md:justify-start">
            <a href={`mailto:${SITE.email}`} class="flex items-center gap-2 text-gray-600 hover:text-blue-600 transition-colors">
              <Mail className="w-5 h-5" />
              <span>{SITE.email}</span>
            </a>
            <a href={SITE.github} target="_blank" class="flex items-center gap-2 text-gray-600 hover:text-blue-600 transition-colors">
              <Github className="w-5 h-5" />
              <span>GitHub</span>
            </a>
            <a href={SITE.linkedin} target="_blank" class="flex items-center gap-2 text-gray-600 hover:text-blue-600 transition-colors">
              <Linkedin className="w-5 h-5" />
              <span>LinkedIn</span>
            </a>
          </div>
          
          <a 
            href="/activities" 
            class="inline-flex items-center gap-2 bg-blue-600 text-white px-8 py-4 rounded-lg font-medium text-lg hover:bg-blue-700 transition-colors shadow-lg hover:shadow-xl"
          >
            {SITE.hero.action}
            <ArrowRight className="w-5 h-5" />
          </a>
        </div>
      </div>
    </div>
  </section>
</Layout>