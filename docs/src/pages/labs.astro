---
import Layout from '../layouts/Layout.astro';
import { getCollection } from 'astro:content';
import { Image } from 'astro:assets';
import { Calendar } from 'lucide-react';

const labs = (await getCollection('labs')).sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());
---

<Layout title="Labs">
  <div class="max-w-7xl mx-auto px-4 py-12 sm:py-20">
    <div class="mb-16">
      <h1 class="text-4xl font-bold text-gray-900 mb-4">Lab Reports</h1>
      <p class="text-lg text-gray-600">
        Documentation of my ECE 5160 Fast Robotics labs.
      </p>
    </div>

    <!-- Labs Grid -->
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
      {labs.map(lab => (
        <a href={`/labs/${lab.id.replace(/\.[^/.]+$/, "")}`} class="group bg-white border border-gray-100 rounded-2xl overflow-hidden hover:shadow-lg transition-all block">
          {lab.data.cover ? (
            <div class="h-56 overflow-hidden bg-gray-100 relative">
              <Image 
                src={lab.data.cover} 
                alt={lab.data.title} 
                class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-105"
                quality={80}
                format="webp"
                width={600}
              />
              <div class="flex items-center text-white/90 text-sm absolute bottom-4 left-4 bg-black/30 px-3 py-1 rounded-full backdrop-blur-sm">
                <Calendar className="w-4 h-4 mr-2" />
                <time>{lab.data.date.toISOString().split('T')[0]}</time>
              </div>
            </div>
          ) : (
            <div class="h-56 bg-gradient-to-br from-blue-100 to-blue-200 flex items-center justify-center">
              <span class="text-blue-600 text-4xl font-bold">{lab.data.title.charAt(0)}</span>
            </div>
          )}
          <div class="p-6">
            <h3 class="text-lg font-bold text-gray-900 mb-2 group-hover:text-blue-600 transition-colors">{lab.data.title}</h3>
            <p class="text-gray-600 text-sm line-clamp-3">{lab.data.description}</p>
          </div>
        </a>
      ))}
      {labs.length === 0 && (
        <div class="col-span-full text-center py-12 bg-gray-50 rounded-xl">
          <p class="text-gray-500">No labs added yet.</p>
        </div>
      )}
    </div>
  </div>
</Layout>