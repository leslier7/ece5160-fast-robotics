---
import Layout from '../layouts/Layout.astro';
import { getCollection } from 'astro:content';
import { Image } from 'astro:assets';

const base = import.meta.env.BASE_URL.endsWith('/') 
  ? import.meta.env.BASE_URL.slice(0, -1) 
  : import.meta.env.BASE_URL;

const labs = (await getCollection('labs')).sort((a, b) => a.data.date.valueOf() - b.data.date.valueOf());
---

<Layout title="Labs">
  <div class="max-w-7xl mx-auto px-4 py-12 sm:py-20">
    <div class="mb-16">
      <h1 class="text-4xl font-bold text-gray-900 mb-4">Lab Reports</h1>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
      {labs.map(lab => {
        const slug = lab.id.replace(/\.mdx?$/, "");
        return (
          <a href={`${base}/labs/${slug}`} class="group bg-white border border-gray-100 rounded-2xl overflow-hidden hover:shadow-lg transition-all block">
            {lab.data.cover ? (
              <div class="overflow-hidden">
                <Image 
                  src={lab.data.cover} 
                  alt={lab.data.title}
                  class="w-full h-auto transition-transform duration-500 group-hover:scale-105"
                  width={400}
                  height={225}
                />
              </div>
            ) : (
              <div class="h-48 bg-gradient-to-br from-blue-100 to-blue-200 flex items-center justify-center">
                <span class="text-blue-600 text-4xl font-bold">{lab.data.title.charAt(0)}</span>
              </div>
            )}
            <div class="p-6">
              <h3 class="text-lg font-bold text-gray-900 mb-2 group-hover:text-blue-600 transition-colors">{lab.data.title}</h3>
              <p class="text-gray-600 text-sm">{lab.data.description}</p>
              <time class="text-gray-400 text-xs">{lab.data.date.toISOString().split('T')[0]}</time>
            </div>
          </a>
        );
      })}
    </div>
  </div>
</Layout>