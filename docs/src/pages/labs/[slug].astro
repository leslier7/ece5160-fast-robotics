---
import Layout from '../../layouts/Layout.astro';
import { getCollection, render } from 'astro:content';

export async function getStaticPaths() {
  const labs = await getCollection('labs');
  return labs.map(lab => ({
    params: { slug: lab.id.replace(/\.[^/.]+$/, "") },
    props: { lab },
  }));
}

const { lab } = Astro.props;
const { Content } = await render(lab);
---

<Layout title={lab.data.title}>
  <article class="max-w-4xl mx-auto px-4 py-12">
    <header class="mb-8">
      <h1 class="text-4xl font-bold text-gray-900 mb-4">{lab.data.title}</h1>
      <time class="text-gray-500">{lab.data.date.toISOString().split('T')[0]}</time>
    </header>
    <div class="prose prose-lg max-w-none">
      <Content />
    </div>
  </article>
</Layout>